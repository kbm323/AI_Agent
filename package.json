{
  "name": "ai-agent",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/public.ts",
    "./role-routing": "./src/role-routing.ts",
    "./execution-persona": "./src/execution-persona.ts",
    "./review-persona": "./src/review-persona.ts",
    "./meeting-loop": "./src/meeting-loop.ts",
    "./discord": "./src/discord-client.ts",
