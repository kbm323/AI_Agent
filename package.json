    "check:meeting-loop-routing": "node scripts/check-meeting-loop-routing.ts",
    "check:meeting-loop-artifacts": "node scripts/check-meeting-loop-artifacts.ts",
    "check:final-synthesis-artifact": "node scripts/check-final-synthesis-artifact.ts",
    "check:final-synthesis-stability": "node scripts/check-final-synthesis-stability.ts",
    "check:decision-determinism": "node scripts/check-decision-determinism.ts",
    "check:escalation-serialization": "node scripts/check-escalation-serialization.ts",
    "check:final-output-schema": "node scripts/check-final-output-schema.ts",
    "check:dry-run-contract": "node scripts/check-dry-run-contract.ts",
    "check:fixture-harness": "node scripts/check-fixture-harness.ts",
    "review-evidence": "node scripts/review-evidence.ts",
    "generate-diagnosis-report": "node scripts/generate-diagnosis-report.ts",
    "generate-token-strategy": "node scripts/generate-token-strategy.ts",
    "check:token-strategy": "node scripts/check-token-strategy.ts",
    "check:token-reduction-savings-band": "node scripts/check-token-reduction-savings-band.ts",
    "check:context-storage-boundary": "node scripts/check-context-storage-boundary.ts",
    "generate-loop-context-compression-policy": "node scripts/generate-loop-context-compression-policy.ts",
    "check:loop-context-compression-policy": "node scripts/check-loop-context-compression-policy.ts",
    "check:loop-context-compression-verification": "node scripts/check-loop-context-compression-verification.ts",
    "check:token-cost-control": "node scripts/check-token-cost-control.ts",
    "check:public-api": "node scripts/check-public-api.ts",
    "check:requirement-gap": "node scripts/check-requirement-gap.ts",
    "check:mvp-completion": "node scripts/check-mvp-completion.ts",
    "check:artifacts": "node scripts/check-artifacts.ts",
    "check:review-artifact-completeness": "node scripts/check-review-artifact-completeness.ts",
    "run-verification-workflow": "node scripts/run-verification-workflow.ts",
    "check:verification-output": "node scripts/check-verification-output.ts",
    "check:typecheck": "node scripts/check-typecheck.ts",
    "check:environment-dependencies": "node scripts/check-environment-dependencies.ts",
    "check:validation-command-documentation": "node scripts/check-validation-command-documentation.ts",
    "typecheck": "node --check src/*.ts && node --check scripts/*.ts && node --check tests/*.ts && node scripts/typecheck-python.mjs",
    "count-loc": "node scripts/count-loc.ts --json",
    "count-loc:table": "node scripts/count-loc.ts",
    "inspect:file-tree": "node scripts/inspect-file-tree.ts",
    "dependency-graph": "node scripts/dependency-graph.ts",
    "dependency-graph:dot": "node scripts/dependency-graph.ts --format dot",
    "lint:ruff": "node scripts/ruff-check.mjs",
